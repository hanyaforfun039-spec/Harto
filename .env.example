# =============================================================================
# Template env — salin jadi `.env` lalu isi nilainya. JANGAN commit `.env`.
# Ambil di Supabase: Settings -> API
#   - Project URL      -> PUBLIC_SUPABASE_URL
#   - Publishable key  -> PUBLIC_SUPABASE_ANON_KEY  (diawali sb_publishable_...)
# Jangan masukkan Secret key (sb_secret_...) ke sini — itu khusus server.
# =============================================================================
PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Site aktif untuk build ini: premium | hybrid | kredit | area
SITE_ID=premium
