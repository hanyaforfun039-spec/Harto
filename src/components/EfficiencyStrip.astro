---
/* EfficiencyStrip — deret metrik angka besar (data display) di atas "gauge"
   metalik. Generic: terima array metrik dari halaman. Dipakai Web2 (hybrid). */
interface Metric {
  value: string;
  unit?: string;
  label: string;
}
interface Props {
  metrics: Metric[];
  eyebrow?: string;
  heading?: string;
  note?: string;
}
const { metrics, eyebrow, heading, note } = Astro.props;
---
<section class="section effstrip" aria-labelledby="eff-h">
  <div class="container">
    {(eyebrow || heading) && (
      <div class="sec-head" data-reveal>
        {eyebrow && <p class="eyebrow">{eyebrow}</p>}
        {heading && <h2 id="eff-h">{heading}</h2>}
      </div>
    )}
    <dl class="eff-grid">
      {metrics.map((m, i) => (
        <div class="eff-item" data-reveal data-reveal-delay={String((i % 3) + 1)}>
          <dt class="eff-num">
            <span class="eff-value tnum">{m.value}</span>
            {m.unit && <span class="eff-unit">{m.unit}</span>}
          </dt>
          <span class="eff-gauge" aria-hidden="true"></span>
          <dd class="eff-label">{m.label}</dd>
        </div>
      ))}
    </dl>
    {note && <p class="eff-note">{note}</p>}
  </div>
</section>

<style>
  .sec-head { display: grid; gap: var(--space-2xs); max-width: 56ch; }
  .eff-grid {
    display: grid;
    gap: var(--space-xl) var(--space-lg);
    margin-top: var(--space-2xl);
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 56rem) { .eff-grid { grid-template-columns: repeat(4, 1fr); } }

  .eff-item { display: grid; gap: var(--space-2xs); }
  .eff-num { display: flex; align-items: baseline; gap: var(--space-3xs); }
  .eff-value {
    font-family: var(--font-display);
    font-size: var(--fs-h1);
    font-weight: var(--fw-bold);
    line-height: 1;
    letter-spacing: var(--ls-tight);
    color: var(--color-accent-ink);
  }
  .eff-unit {
    font-family: var(--font-display);
    font-size: var(--fs-h5);
    font-weight: var(--fw-semibold);
    color: var(--color-text-subtle);
  }
  .eff-gauge {
    position: relative;
    display: block;
    height: 0.7rem;
  }
  .eff-gauge::before {
    content: ''; position: absolute; inset: 0 0 auto 0; height: 0.5rem;
    background-image: repeating-linear-gradient(90deg, var(--color-border-strong) 0 1px, transparent 1px 9px);
  }
  .eff-gauge::after {
    content: ''; position: absolute; left: 0; right: 0; bottom: 0; height: 2px;
    background: linear-gradient(90deg, var(--color-accent) 0 70%, var(--color-border) 70% 100%);
  }
  .eff-label {
    font-size: var(--fs-body-sm);
    color: var(--color-text-muted);
    max-width: 24ch;
  }
  .eff-note {
    margin-top: var(--space-xl);
    font-size: var(--fs-caption);
    color: var(--color-text-subtle);
    max-width: 70ch;
  }
</style>
