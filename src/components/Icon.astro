---
/* Icon — set ikon SVG inline (stroke = currentColor). NOL emoji di UI.
   WhatsApp memakai glyph brand resmi (filled). a11y: dekoratif -> aria-hidden,
   bermakna -> beri prop `label` (jadi role="img" + aria-label). */
interface Props {
  name: string;
  size?: number;
  class?: string;
  label?: string;
  strokeWidth?: number;
}
const { name, size = 24, class: className = '', label, strokeWidth = 1.6 } = Astro.props;
const filled = name === 'whatsapp' || name === 'tiktok';

const icons: Record<string, string> = {
  whatsapp:
    '<path d="M19.05 4.91A9.82 9.82 0 0 0 12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38a9.9 9.9 0 0 0 4.79 1.22h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.02m-7.01 15.24h-.01a8.2 8.2 0 0 1-4.18-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.18 8.18 0 0 1-1.26-4.38c0-4.54 3.7-8.23 8.24-8.23 2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23m4.52-6.16c-.25-.12-1.47-.72-1.69-.81-.23-.08-.39-.12-.56.12-.16.25-.64.81-.79.97-.14.17-.29.19-.54.06-.25-.12-1.05-.39-1.99-1.23-.74-.66-1.23-1.47-1.38-1.72-.14-.25-.01-.38.11-.5.11-.11.25-.29.37-.43.13-.14.17-.25.25-.42.08-.16.04-.31-.02-.43-.06-.12-.56-1.35-.77-1.84-.2-.48-.4-.42-.56-.43-.14-.01-.31-.01-.47-.01-.17 0-.43.06-.66.31-.23.25-.86.85-.86 2.07s.89 2.4 1.01 2.56c.12.17 1.75 2.67 4.23 3.74.59.26 1.05.41 1.41.52.59.19 1.13.16 1.56.1.48-.07 1.47-.6 1.67-1.18.21-.58.21-1.07.14-1.18-.06-.1-.22-.16-.47-.28"/>',
  check: '<polyline points="20 6 9 17 4 12"/>',
  'arrow-right': '<line x1="4" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>',
  'chevron-down': '<polyline points="6 9 12 15 18 9"/>',
  menu: '<line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>',
  close: '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>',
  phone:
    '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.8 19.8 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.8 19.8 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.69 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.33 1.85.56 2.81.69A2 2 0 0 1 22 16.92"/>',
  clock: '<circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15 14"/>',
  'map-pin': '<path d="M21 10c0 6-9 12-9 12s-9-6-9-12a9 9 0 0 1 18 0Z"/><circle cx="12" cy="10" r="3"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><polyline points="3 7 12 13 21 7"/>',
  /* social */
  instagram:
    '<rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17" cy="7" r="1.1" fill="currentColor" stroke="none"/>',
  tiktok:
    '<path d="M16.6 5.8a4.3 4.3 0 0 1-1-2.8h-3.1v11.9a2.4 2.4 0 1 1-2.4-2.4c.2 0 .5 0 .7.1V9.4a5.5 5.5 0 1 0 4.8 5.4V8.3a6.3 6.3 0 0 0 3.7 1.2V6.4a4.3 4.3 0 0 1-2.7-.6z"/>',
  /* spec icons */
  engine:
    '<path d="M5 9h2V7h4l2 2h3v2h2l1 1v3h-3v2h-4l-2-2H7v-2H5z"/>',
  power: '<path d="M13 2 4 14h7l-1 8 10-13h-7z"/>',
  torque: '<path d="M21 12a9 9 0 1 1-3-6.7"/><polyline points="21 3 21 9 15 9"/>',
  drivetrain:
    '<circle cx="7" cy="7" r="2"/><circle cx="17" cy="7" r="2"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/><line x1="7" y1="9" x2="7" y2="15"/><line x1="17" y1="9" x2="17" y2="15"/><line x1="9" y1="7" x2="15" y2="7"/><line x1="9" y1="17" x2="15" y2="17"/>',
  fuel:
    '<line x1="3" y1="22" x2="13" y2="22"/><rect x="4" y="3" width="8" height="19" rx="1"/><path d="M12 8h3l2 2v7a2 2 0 0 0 4 0V9l-3-3"/>',
  range: '<path d="M3 12h13"/><polyline points="12 7 17 12 12 17"/><path d="M20 7v10"/>',
  battery:
    '<rect x="3" y="8" width="16" height="9" rx="1.5"/><line x1="21" y1="11" x2="21" y2="14"/><path d="M11 9.5 9 13h2.5L10 16"/>',
  transmission:
    '<circle cx="6" cy="6" r="1.5"/><circle cx="12" cy="6" r="1.5"/><circle cx="18" cy="6" r="1.5"/><path d="M6 7.5v9M12 7.5V12M18 7.5v9M6 12h6"/>',
};
const inner = icons[name] ?? '';
const a11y = label
  ? { role: 'img', 'aria-label': label }
  : { 'aria-hidden': 'true', focusable: 'false' };
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill={filled ? 'currentColor' : 'none'}
  stroke={filled ? 'none' : 'currentColor'}
  stroke-width={filled ? undefined : strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={`icon ${className}`}
  {...a11y}
  set:html={inner}
/>

<style>
  .icon {
    display: inline-block;
    flex: none;
    vertical-align: middle;
  }
</style>
