---
/* CarImage — optimasi gambar mobil via Astro <Picture> (AVIF/WebP + srcset),
   dengan placeholder rapi otomatis bila foto asli belum ada (build tetap jalan).
   Taruh foto di src/assets/cars/<slug>/<file> sesuai cars.json -> auto-optimize.
   Hero: set priority -> loading=eager + fetchpriority=high (LCP cepat, no CLS). */
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: string; // "j8-ardis/hero.jpg"
  alt: string;
  label?: string; // teks placeholder (mis. namaPendek)
  widths?: number[];
  sizes?: string;
  ratio?: string; // "16 / 10"
  priority?: boolean;
  class?: string;
}
const {
  src,
  alt,
  label,
  widths = [400, 800, 1200],
  sizes = '(max-width: 768px) 100vw, 800px',
  ratio = '16 / 10',
  priority = false,
  class: className = '',
} = Astro.props;

// Semua aset mobil (eager). Folder boleh kosong -> map kosong -> placeholder.
const assets = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/cars/**/*.{jpg,jpeg,png,webp,avif}',
  { eager: true },
);
// URL absolut (mis. Supabase Storage publik) -> <img> apa adanya (tanpa optimasi build).
// Path relatif -> aset lokal yg di-optimasi <Picture>. Kosong/hilang -> placeholder.
const isRemote = /^https?:\/\//.test(src);
const mod = isRemote ? undefined : assets[`/src/assets/cars/${src}`];
---
{
  isRemote ? (
    <img
      src={src}
      alt={alt}
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      decoding={priority ? 'auto' : 'async'}
      class={`carimg ${className}`}
      style={`aspect-ratio:${ratio}`}
    />
  ) : mod ? (
    <Picture
      src={mod.default}
      alt={alt}
      widths={widths}
      sizes={sizes}
      formats={['avif', 'webp']}
      loading={priority ? 'eager' : 'lazy'}
      fetchpriority={priority ? 'high' : 'auto'}
      decoding={priority ? 'auto' : 'async'}
      class={`carimg ${className}`}
      style={`aspect-ratio:${ratio}`}
    />
  ) : (
    <div
      class={`carimg carimg--ph ${className}`}
      style={`aspect-ratio:${ratio}`}
      role="img"
      aria-label={alt}
    >
      <svg viewBox="0 0 64 28" aria-hidden="true" focusable="false">
        <path
          d="M4 21h56M9 21c-2 0-3-1-3-3l1-4c.4-1.6 1.6-2.6 3-3l4-3c1.4-1 2.6-1.4 4-1.4h12c1.6 0 3 .6 4.3 1.7l4 3.4 9 1.3c2 .3 3.4 1.4 3.7 3l.4 2.7c.2 1.6-1 3-2.6 3"
          fill="none"
          stroke="currentColor"
          stroke-width="1.2"
          stroke-linejoin="round"
        />
        <circle cx="18" cy="21" r="3.4" fill="none" stroke="currentColor" stroke-width="1.2" />
        <circle cx="46" cy="21" r="3.4" fill="none" stroke="currentColor" stroke-width="1.2" />
      </svg>
      {label && <span class="carimg-ph-label">{label}</span>}
      <span class="carimg-ph-note">Foto menyusul</span>
    </div>
  )
}

<style>
  .carimg {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
    border-radius: var(--radius-lg);
    background: var(--color-surface-2);
  }
  .carimg--ph {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2xs);
    color: var(--color-text-subtle);
    background:
      radial-gradient(120% 90% at 50% 0%, var(--color-surface) 0%, var(--color-surface-2) 70%);
    border: 1px solid var(--color-border);
  }
  .carimg--ph svg { width: 42%; max-width: 14rem; color: var(--n-300); }
  .carimg-ph-label {
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-h5);
    color: var(--color-text-muted);
    letter-spacing: var(--ls-snug);
  }
  .carimg-ph-note {
    font-size: var(--fs-caption);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
  }
</style>
