---
/* CreditCalculator — simulasi cicilan (bunga flat).
   Progressive enhancement: server merender hasil DEFAULT (berfungsi tanpa JS),
   lalu calculator.ts membuat slider & select interaktif + update link WhatsApp. */
import Button from './Button.astro';
import type { Car, SiteConfig } from '../lib/types';
import { hargaMulai } from '../lib/cars';
import { hitungCicilan } from '../lib/credit';
import { formatRupiah, formatRupiahShort } from '../lib/format';
import { pesanSimulasiKredit, waLink } from '../lib/whatsapp';

interface Props {
  cars: Car[];
  site: SiteConfig;
  preselectSlug?: string;
  heading?: string;
}
const { cars, site, preselectSlug, heading = 'Simulasi Kredit' } = Astro.props;

const selected = cars.find((c) => c.slug === preselectSlug) ?? cars[0];
const dp = site.kredit.dpDefaultPct;
const tenor = site.kredit.tenorDefaultYears;
const bunga = site.kredit.bungaFlatPctPerYear;
const otr = hargaMulai(selected);
const r = hitungCicilan({ otr, dpPct: dp, tenorYears: tenor, bungaFlatPctPerYear: bunga });
const waDefault = waLink(site.whatsapp, pesanSimulasiKredit(site, selected.nama, r));
---
<div
  class="calc"
  data-calculator
  data-wa={site.whatsapp}
  data-bunga={bunga}
  data-sales={site.salesName}
>
  <div class="calc-controls">
    <h3 class="calc-heading">{heading}</h3>

    <div class="field">
      <label for="calc-model">Pilih model</label>
      <div class="select-wrap">
        <select id="calc-model" class="calc-model">
          {cars.map((c) => (
            <option value={c.slug} data-otr={hargaMulai(c)} data-nama={c.nama} selected={c.slug === selected.slug}>
              {c.nama} — mulai {formatRupiahShort(hargaMulai(c))}
            </option>
          ))}
        </select>
      </div>
    </div>

    <div class="field">
      <label for="calc-dp">Uang muka (DP) <output class="calc-dp-out">{dp}%</output></label>
      <input id="calc-dp" class="calc-dp" type="range" min="10" max="50" step="5" value={dp} />
      <div class="range-ends"><span>10%</span><span>50%</span></div>
    </div>

    <div class="field">
      <label for="calc-tenor">Tenor <output class="calc-tenor-out">{tenor} tahun</output></label>
      <input id="calc-tenor" class="calc-tenor" type="range" min="1" max="7" step="1" value={tenor} />
      <div class="range-ends"><span>1 thn</span><span>7 thn</span></div>
    </div>
  </div>

  <div class="calc-result">
    <p class="calc-result-label">Estimasi cicilan per bulan</p>
    <p class="calc-cicilan price">{formatRupiah(r.cicilanPerBulan)}</p>

    <dl class="calc-breakdown">
      <div><dt>Harga OTR</dt><dd class="calc-otr tnum">{formatRupiah(otr)}</dd></div>
      <div><dt>DP (<span class="calc-dp-pct">{dp}</span>%)</dt><dd class="calc-dpamount tnum">{formatRupiah(r.dp)}</dd></div>
      <div><dt>Pokok kredit</dt><dd class="calc-pokok tnum">{formatRupiah(r.pokok)}</dd></div>
      <div><dt>Tenor</dt><dd class="calc-tenor-months tnum">{r.tenorMonths} bln</dd></div>
    </dl>

    <Button href={waDefault} variant="whatsapp" iconLeft="whatsapp" class="calc-wa" target="_blank" block>
      Kirim simulasi ini ke WhatsApp
    </Button>
    <p class="calc-note">Bunga {bunga}% flat/tahun. Estimasi non-mengikat; angka final mengikuti pihak leasing.</p>
  </div>
</div>

<script>
  import '../scripts/calculator.ts';
</script>

<style>
  .calc {
    display: grid;
    gap: 0;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-md);
  }
  @media (min-width: 48rem) {
    .calc { grid-template-columns: 1fr 1fr; }
  }

  .calc-controls { padding: var(--space-lg); display: grid; gap: var(--space-md); align-content: start; }
  .calc-heading { font-size: var(--fs-h4); }

  .field { display: grid; gap: var(--space-2xs); }
  .field label {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: var(--fs-body-sm); font-weight: var(--fw-medium); color: var(--color-text);
  }
  .field output { font-weight: var(--fw-semibold); color: var(--color-accent-ink); font-variant-numeric: tabular-nums; }

  .select-wrap { position: relative; }
  .select-wrap::after {
    content: ''; position: absolute; right: var(--space-sm); top: 50%;
    width: 0.5rem; height: 0.5rem; border-right: 2px solid var(--color-text-muted);
    border-bottom: 2px solid var(--color-text-muted); transform: translateY(-65%) rotate(45deg);
    pointer-events: none;
  }
  select.calc-model {
    width: 100%; min-height: var(--tap-min);
    padding: var(--space-2xs) var(--space-xl) var(--space-2xs) var(--space-sm);
    background: var(--color-bg); border: 1.5px solid var(--color-border-strong);
    border-radius: var(--radius-md); appearance: none; cursor: pointer;
    font-size: var(--fs-body-sm);
  }

  input[type='range'] {
    width: 100%; height: var(--tap-min); cursor: pointer;
    accent-color: var(--color-accent); background: transparent;
  }
  .range-ends { display: flex; justify-content: space-between; font-size: var(--fs-caption); color: var(--color-text-subtle); margin-top: calc(-1 * var(--space-2xs)); }

  .calc-result {
    padding: var(--space-lg);
    background: var(--color-surface-2);
    border-top: 1px solid var(--color-border);
    display: grid; gap: var(--space-sm); align-content: start;
  }
  @media (min-width: 48rem) {
    .calc-result { border-top: 0; border-left: 1px solid var(--color-border); }
  }
  .calc-result-label { font-size: var(--fs-body-sm); color: var(--color-text-muted); }
  .calc-cicilan { font-size: var(--fs-price); line-height: 1; color: var(--color-accent-ink); }

  .calc-breakdown { display: grid; gap: var(--space-2xs); }
  .calc-breakdown > div {
    display: flex; justify-content: space-between; gap: var(--space-sm);
    padding-bottom: var(--space-2xs); border-bottom: 1px solid var(--color-border);
    font-size: var(--fs-body-sm);
  }
  .calc-breakdown dt { color: var(--color-text-muted); }
  .calc-breakdown dd { font-weight: var(--fw-semibold); }

  .calc-wa { margin-top: var(--space-2xs); }
  .calc-note { font-size: var(--fs-caption); color: var(--color-text-subtle); }
</style>
