---
/* LineupSpec — "Model JAECOO": rak geser HORIZONTAL berisi kartu model
   (foto + tag powertrain + nama + harga + CTA). Snap, ringan, gaya katalog. */
import CarImage from './CarImage.astro';
import Button from './Button.astro';
import type { Car, SiteConfig } from '../lib/types';
import { hargaMulai } from '../lib/cars';
import { formatRupiahShort } from '../lib/format';
import { linkTestDrive } from '../lib/whatsapp';

interface Props { cars: Car[]; site: SiteConfig }
const { cars, site } = Astro.props;

const tagOf = (c: Car) =>
  c.powertrain === 'phev' ? 'Hybrid · PHEV' : c.powertrain === 'ev' ? 'Listrik · EV' : 'Bensin';

/* Override foto khusus section ini (banner di bucket Harto). */
const fotoOverride: Record<string, string> = {
  'j5': 'https://fxjspvdkeybabxotniov.supabase.co/storage/v1/object/public/Harto/j5%20banner3.webp',
  'j7-shs': 'https://fxjspvdkeybabxotniov.supabase.co/storage/v1/object/public/Harto/J7%20banner3%20(1).webp',
};
---
<section class="section section--lg lineupspec" id="lineup" aria-labelledby="ls-h">
  <div class="container">
    <div class="ls-head" data-reveal>
      <p class="eyebrow">Lineup</p>
      <h2 id="ls-h">Model JAECOO</h2>
      <p class="lead">Pilih model JAECOO Anda.</p>
    </div>

    <ol class="ls-rail" role="list">
      {cars.map((car, i) => {
        const detail = `/mobil/${car.slug}`;
        return (
          <li class="ls-card" data-reveal>
            <a class="ls-media" href={detail} tabindex="-1" aria-hidden="true">
              <CarImage src={fotoOverride[car.slug] ?? car.foto.hero.src} alt={car.foto.hero.alt} label={car.namaPendek} priority={i === 0} ratio="16 / 10" sizes="20rem" />
            </a>
            <div class="ls-body">
              <p class={`ls-tag ls-tag--${car.powertrain}`}>{tagOf(car)}</p>
              <h3 class="ls-name"><a href={detail}>{car.nama}</a></h3>
              <p class="ls-price"><span class="ls-price-lbl">Mulai</span> <span class="price">{formatRupiahShort(hargaMulai(car))}</span></p>
              <div class="ls-cta">
                <Button href={detail} variant="primary" size="sm" icon="arrow-right">Detail</Button>
                <Button href={linkTestDrive(site, car.nama)} variant="whatsapp" size="sm" iconLeft="whatsapp" target="_blank">Test Drive</Button>
              </div>
            </div>
          </li>
        );
      })}
    </ol>
  </div>
</section>

<style>
  .ls-head { display: grid; gap: var(--space-2xs); max-width: 56ch; }

  /* Rak geser horizontal (bleed ke tepi viewport, snap) */
  .ls-rail {
    margin-top: var(--space-2xl);
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: minmax(15.5rem, 20rem);
    gap: var(--space-lg);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-padding-left: var(--gutter);
    margin-inline: calc(-1 * var(--gutter));
    padding-inline: var(--gutter);
    padding-bottom: var(--space-sm);
    scrollbar-width: none;
  }
  .ls-rail::-webkit-scrollbar { display: none; }

  .ls-card {
    scroll-snap-align: start;
    display: grid;
    grid-template-rows: auto 1fr;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--dur) var(--ease), transform var(--dur) var(--ease-out);
  }
  .ls-card:hover { box-shadow: var(--shadow-md); transform: translateY(-3px); }

  .ls-media { display: block; overflow: hidden; }
  .ls-media :global(.carimg) { border-radius: 0; transition: transform var(--dur-slow) var(--ease-out); }
  .ls-card:hover .ls-media :global(.carimg) { transform: scale(1.04); }

  .ls-body { display: grid; gap: var(--space-2xs); align-content: start; padding: var(--space-lg); }
  .ls-tag {
    justify-self: start;
    font-size: var(--fs-caption);
    font-weight: var(--fw-semibold);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    padding: var(--space-3xs) var(--space-xs);
    border-radius: var(--radius-pill);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text-muted);
  }
  .ls-tag--phev, .ls-tag--ev {
    color: var(--color-accent-ink);
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
  }
  .ls-name { font-size: var(--fs-h4); margin-top: var(--space-3xs); }
  .ls-name a { color: inherit; }
  .ls-name a:hover { color: var(--color-accent-ink); }
  .ls-price { display: flex; align-items: baseline; gap: var(--space-2xs); margin-top: var(--space-3xs); }
  .ls-price-lbl { font-size: var(--fs-caption); text-transform: uppercase; letter-spacing: var(--ls-wide); color: var(--color-text-subtle); }
  .ls-price .price { font-size: var(--fs-h5); font-weight: var(--fw-bold); }
  .ls-cta { display: flex; flex-wrap: wrap; gap: var(--space-2xs); margin-top: var(--space-sm); }
</style>
