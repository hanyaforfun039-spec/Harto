---
/* TestDriveForm — Web2 "Harto" borang INSTRUMEN terang. Dibedakan dari Faiz
   (kartu gelap, field 2 kolom select) & Putri (ledger garis-bawah bernomor):
   panel terang soft-radius, input boxed, dan PILIHAN = SEGMENTED CONTROL (radio
   chip) untuk rencana & cara bayar.
   Kontrak TIDAK berubah: [data-td-form] + nama/telp/mobil/rencana/bayar → testdrive.ts. */
import Button from './Button.astro';
import type { Car, SiteConfig } from '../lib/types';
import { linkPenawaran } from '../lib/whatsapp';

interface Props { cars: Car[]; site: SiteConfig; preselectSlug?: string }
const { cars, site, preselectSlug } = Astro.props;
const selected = cars.find((c) => c.slug === preselectSlug) ?? cars[0];

const rencanaOpts = ['Bulan ini', '1-3 bulan', 'Masih survei'];
const bayarOpts = ['Kredit', 'Tunai', 'Belum tahu'];
---
<section class="td section section--lg" id="test-drive" aria-labelledby="td-h">
  <div class="container container--narrow">
    <div class="td-head" data-reveal>
      <p class="eyebrow">Test Drive</p>
      <h2 id="td-h">Jadwalkan test drive J7 SHS</h2>
      <p class="lead">Isi data singkat. Saat dikirim, WhatsApp {site.salesName} terbuka berisi pesan yang sudah tersusun — tanpa data tersimpan di server.</p>
    </div>

    <form
      class="td-form"
      data-td-form
      data-wa={site.whatsapp}
      data-sales={site.salesName}
      data-area={site.address.locality}
      data-reveal
    >
      <div class="td-row">
        <div class="td-field">
          <label for="td-nama">Nama</label>
          <input id="td-nama" name="nama" type="text" autocomplete="name" required placeholder="Nama lengkap" />
        </div>
        <div class="td-field">
          <label for="td-wa">Nomor WhatsApp</label>
          <input id="td-wa" name="telp" type="tel" inputmode="numeric" autocomplete="tel" pattern="[0-9+ ]{8,16}" required placeholder="08xxxxxxxxxx" />
        </div>
      </div>

      <div class="td-field">
        <label for="td-mobil">Model</label>
        <div class="select-wrap">
          <select id="td-mobil" name="mobil" required>
            {cars.map((c) => (
              <option value={c.nama} selected={c.slug === selected.slug}>{c.nama}</option>
            ))}
          </select>
        </div>
      </div>

      <fieldset class="td-seg">
        <legend>Rencana beli</legend>
        <div class="td-chips">
          {rencanaOpts.map((o, i) => (
            <label class="td-chip">
              <input type="radio" name="rencana" value={o} checked={i === 0} />
              <span>{o}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <fieldset class="td-seg">
        <legend>Cara bayar</legend>
        <div class="td-chips">
          {bayarOpts.map((o, i) => (
            <label class="td-chip">
              <input type="radio" name="bayar" value={o} checked={i === 0} />
              <span>{o}</span>
            </label>
          ))}
        </div>
      </fieldset>

      <Button type="submit" variant="whatsapp" size="lg" iconLeft="whatsapp" block>Kirim ke WhatsApp</Button>
      <p class="td-note">Dengan menekan tombol, WhatsApp akan terbuka berisi data di atas.</p>
      <noscript>
        <p><a href={linkPenawaran(site)} target="_blank" rel="noopener">Hubungi {site.salesName} via WhatsApp</a></p>
      </noscript>
    </form>
  </div>
</section>

<script>
  import '../scripts/testdrive.ts';
</script>

<style>
  .td-head { display: grid; gap: var(--space-2xs); max-width: 52ch; }

  .td-form {
    display: grid;
    gap: var(--space-lg);
    margin-top: var(--space-xl);
    padding: var(--space-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .td-row { display: grid; gap: var(--space-lg); }
  @media (min-width: 36rem) { .td-row { grid-template-columns: 1fr 1fr; } }
  .td-field { display: grid; gap: var(--space-2xs); }
  .td-field label, .td-seg legend {
    font-size: var(--fs-body-sm); font-weight: var(--fw-semibold); color: var(--color-text);
  }

  input[type='text'], input[type='tel'], select {
    width: 100%;
    min-height: var(--tap-min);
    padding: var(--space-2xs) var(--space-sm);
    background: var(--color-bg);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    font-size: var(--fs-body);
    color: var(--color-text);
  }
  input::placeholder { color: var(--color-text-subtle); }
  input:focus-visible, select:focus-visible { outline: 2px solid var(--color-accent); outline-offset: 1px; border-color: var(--color-accent); }
  input:invalid:not(:placeholder-shown) { border-color: var(--color-danger); }

  .select-wrap { position: relative; }
  select { appearance: none; padding-right: var(--space-xl); cursor: pointer; }
  .select-wrap::after {
    content: ''; position: absolute; right: var(--space-sm); top: 50%;
    width: 0.5rem; height: 0.5rem;
    border-right: 2px solid var(--color-text-muted); border-bottom: 2px solid var(--color-text-muted);
    transform: translateY(-65%) rotate(45deg); pointer-events: none;
  }

  /* Segmented control (radio chips) — pembeda khas Harto */
  .td-seg { border: 0; padding: 0; margin: 0; display: grid; gap: var(--space-2xs); }
  .td-chips { display: flex; flex-wrap: wrap; gap: var(--space-2xs); }
  .td-chip { position: relative; }
  .td-chip input {
    position: absolute; opacity: 0; width: 1px; height: 1px;
  }
  .td-chip span {
    display: inline-flex; align-items: center;
    min-height: var(--tap-min);
    padding-inline: var(--space-md);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    font-size: var(--fs-body-sm);
    font-weight: var(--fw-medium);
    color: var(--color-text-muted);
    cursor: pointer;
    transition: border-color var(--dur) var(--ease), background var(--dur) var(--ease), color var(--dur) var(--ease);
  }
  .td-chip input:hover + span { border-color: var(--color-text-subtle); color: var(--color-text); }
  .td-chip input:checked + span {
    border-color: var(--color-accent);
    background: var(--color-accent-soft);
    color: var(--color-accent-ink);
    font-weight: var(--fw-semibold);
  }
  .td-chip input:focus-visible + span { outline: 2px solid var(--color-accent); outline-offset: 2px; }

  .td-note { font-size: var(--fs-caption); color: var(--color-text-subtle); }
</style>
