---
/* TrustHybrid — Web2 "Harto" FORMAT KE-3 (beda dari Faiz grid-kartu & Putri
   pull-quote serif): "trust metrics" instrumen (angka kepercayaan) sebagai
   elemen utama + kutipan RINGKAS terukur (baris, bukan blockquote display) +
   satu baris konsultan. Angka [bracket] = placeholder diisi data resmi. */
import Icon from './Icon.astro';
import type { SiteConfig } from '../lib/types';

interface Props { site: SiteConfig }
const { site } = Astro.props;

/* Foto profil konsultan (Supabase Storage bucket "Harto"). */
const consultantPhoto = 'https://fxjspvdkeybabxotniov.supabase.co/storage/v1/object/public/Harto/Foto%20Harto.webp';

const metrics = [
  { value: '[4,9]', unit: '/ 5', label: 'Kepuasan layanan' },
  { value: '[120]', unit: '+', label: 'Keluarga beralih ke hybrid' },
  { value: String(site.serviceAreas.length), unit: 'kota', label: 'Area layanan Jawa Tengah' },
];
---
<section class="section section--lg trusthybrid" id="trust" aria-labelledby="th-h">
  <div class="container">
    <div class="th-head" data-reveal>
      <p class="eyebrow">Bukti &amp; Pengalaman</p>
      <h2 id="th-h">Mereka sudah merasakan efisiensinya</h2>
    </div>

    <!-- Trust metrics: tile instrumen (angka mono) -->
    <dl class="th-metrics" data-reveal>
      {metrics.map((m) => (
        <div class="th-metric">
          <dt class="th-metric-label">{m.label}</dt>
          <dd class="th-metric-val"><span class="th-metric-num tnum">{m.value}</span><span class="th-metric-unit">{m.unit}</span></dd>
        </div>
      ))}
    </dl>

    <!-- Kutipan ringkas (baris terukur, bukan pull-quote) -->
    <ul class="th-quotes" role="list">
      {site.testimoni.map((t, i) => (
        <li class="th-quote" data-reveal data-reveal-delay={String((i % 2) + 1)}>
          <p class="th-quote-text">{t.teks}</p>
          <p class="th-quote-by"><span class="th-name">{t.nama}</span><span class="th-meta tnum">{t.kota} · JAECOO {t.mobil}</span></p>
        </li>
      ))}
    </ul>

    <aside class="th-consultant" data-reveal>
      <img class="th-c-photo" src={consultantPhoto} alt={`Foto ${site.salesName}, ${site.salesTitle}`} width="1024" height="1536" loading="lazy" decoding="async" />
      <div class="th-c-id">
        <span class="th-c-eyebrow">Konsultan Anda</span>
        <span class="th-c-name">{site.salesName} — {site.salesTitle}</span>
      </div>
      <span class="th-c-contact"><Icon name="phone" size={15} label="Telepon" /> <span class="tnum">{site.phoneDisplay}</span></span>
    </aside>
  </div>
</section>

<style>
  .th-head { display: grid; gap: var(--space-2xs); max-width: 56ch; }

  /* Trust metrics — tile instrumen terang, angka monospace */
  .th-metrics { margin-top: var(--space-2xl); display: grid; gap: var(--space-md); }
  @media (min-width: 44rem) { .th-metrics { grid-template-columns: repeat(3, 1fr); gap: var(--space-lg); } }
  .th-metric {
    display: grid; gap: var(--space-2xs);
    padding: var(--space-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    border-top: 2px solid var(--color-accent);
  }
  .th-metric-val { display: flex; align-items: baseline; gap: var(--space-2xs); }
  .th-metric-num {
    font-family: var(--font-mono);
    font-size: var(--fs-display);
    font-weight: var(--fw-bold);
    line-height: 1;
    letter-spacing: var(--ls-tight);
    color: var(--color-accent-ink);
  }
  .th-metric-unit { font-family: var(--font-mono); font-size: var(--fs-h5); color: var(--color-text-subtle); }
  .th-metric-label { font-size: var(--fs-body-sm); color: var(--color-text-muted); }

  /* Kutipan ringkas (baris) */
  .th-quotes { margin-top: var(--space-2xl); display: grid; gap: var(--space-lg); }
  @media (min-width: 52rem) { .th-quotes { grid-template-columns: 1fr 1fr; gap: var(--space-2xl); } }
  .th-quote {
    display: grid; gap: var(--space-sm);
    padding-left: var(--space-md);
    border-left: 3px solid var(--color-accent);
  }
  .th-quote-text { font-size: var(--fs-lead); line-height: var(--lh-snug); color: var(--color-text); }
  .th-quote-by { display: flex; flex-wrap: wrap; align-items: baseline; gap: var(--space-2xs) var(--space-sm); }
  .th-name { font-weight: var(--fw-semibold); color: var(--color-text); }
  .th-meta { font-size: var(--fs-caption); letter-spacing: var(--ls-wide); text-transform: uppercase; color: var(--color-text-subtle); }

  /* Konsultan — satu baris ramping */
  .th-consultant {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
    display: flex; flex-wrap: wrap; align-items: center; gap: var(--space-sm) var(--space-lg);
  }
  .th-c-photo {
    width: 3.25rem; height: 4.25rem; flex: none;
    border-radius: var(--radius-md);
    object-fit: cover; object-position: center 20%;
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-sm);
  }
  .th-c-id { display: grid; gap: 2px; }
  .th-c-eyebrow { font-size: var(--fs-caption); text-transform: uppercase; letter-spacing: var(--ls-eyebrow); color: var(--color-accent-ink); }
  .th-c-name { font-family: var(--font-display); font-weight: var(--fw-semibold); font-size: var(--fs-h6); color: var(--color-text); }
  .th-c-contact { display: inline-flex; align-items: center; gap: var(--space-2xs); font-size: var(--fs-body-sm); color: var(--color-text-muted); margin-left: auto; }
  .th-c-contact :global(.icon) { color: var(--color-accent-ink); }
</style>
