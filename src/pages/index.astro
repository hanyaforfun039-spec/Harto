---
/* Beranda Web2 "Harto" — JAECOO Hybrid (tema TERANG, SITE_ID=hybrid).
   Tampilan SIMPEL (tanpa kalkulator / angka efisiensi): hero foto + CTA,
   teknologi SHS (kualitatif), lineup, promo, trust, galeri serah terima, form. */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import TechSection from '../components/TechSection.astro';
import LineupSpec from '../components/LineupSpec.astro';
import PromoHybrid from '../components/PromoHybrid.astro';
import TrustHybrid from '../components/TrustHybrid.astro';
import DeliveryGallery from '../components/DeliveryGallery.astro';
import TestDriveForm from '../components/TestDriveForm.astro';
import StickyWhatsAppBar from '../components/StickyWhatsAppBar.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { site } from '../lib/site';
import { getLineup, getCarBySlug } from '../lib/cars';
import { linkTestDrive } from '../lib/whatsapp';
import { organizationSchema, webSiteSchema, faqPageSchema } from '../lib/schema';

const lineup = getLineup(site);
const heroCar = getCarBySlug(site.heroCarSlug) ?? lineup[0];
const kota = site.address.locality;

const siteUrl = Astro.site ?? new URL('https://jaecoo-semarang.example');

/* FAQ beranda (intent hybrid/listrik lokal) — juga FAQPage JSON-LD. */
const homeFaq = [
  {
    q: 'Apa beda mobil hybrid (PHEV) dan mobil listrik (EV) JAECOO?',
    a: 'JAECOO J7 SHS adalah hybrid plug-in (PHEV): bisa berjalan penuh listrik untuk harian dan memakai bensin untuk jarak jauh. JAECOO J5 EV bertenaga listrik penuh tanpa bensin. Keduanya jauh lebih hemat biaya energi dibanding SUV bensin biasa.',
  },
  {
    q: `Apakah melayani pembelian mobil hybrid & listrik di luar Kota ${kota}?`,
    a: `Ya. Kami melayani ${kota}, Ungaran, Salatiga, Kendal, Demak, hingga Solo (Surakarta) dan area Jawa Tengah lainnya — termasuk test drive dan serah terima lintas kota.`,
  },
  {
    q: 'Apakah mobil listrik JAECOO J5 EV perlu charger di rumah?',
    a: 'Tidak wajib, tetapi disarankan. J5 EV bisa diisi di stasiun pengisian umum dan pengisian cepat DC; home charger membuat pengisian harian lebih praktis dan murah.',
  },
  {
    q: 'Apakah servis mobil hybrid JAECOO lebih mahal?',
    a: 'Tidak harus. Pengereman regeneratif memperpanjang usia kampas rem, interval servis mengikuti panduan pabrikan, dan baterai memiliki garansi resmi.',
  },
];

const homeSchemas = [
  organizationSchema(site, siteUrl.href),
  webSiteSchema(site, siteUrl.href),
  faqPageSchema(homeFaq),
];

const homeDescription =
  `Dealer resmi JAECOO Semarang untuk mobil hybrid & listrik: J7 SHS (PHEV) & J5 EV. ` +
  `SUV hemat BBM — test drive & konsultasi. Melayani Semarang, Solo & Jawa Tengah.`;

const techPoin = [
  { icon: 'battery', judul: 'Mode listrik untuk harian', teks: 'Untuk komuter dalam kota, J7 SHS dapat berjalan penuh listrik — senyap, responsif, tanpa konsumsi bensin.' },
  { icon: 'engine', judul: 'Mesin bekerja di titik teririt', teks: 'Saat dibutuhkan, mesin bensin Super Hybrid menyala pada putaran paling efisien sambil mengisi ulang baterai.' },
  { icon: 'range', judul: 'Jangkauan tanpa cemas', teks: 'Gabungan bensin dan listrik memberi jarak tempuh jauh — lintas kota tanpa berhenti mengisi daya.' },
  { icon: 'fuel', judul: 'Hemat di tiap kilometer', teks: 'Konsumsi gabungan yang sangat rendah menekan biaya energi harian secara signifikan.' },
];
---
<BaseLayout
  title="Beranda"
  seoTitle="Mobil Hybrid & Listrik JAECOO Semarang — SUV Hemat BBM"
  description={homeDescription}
  jsonLd={homeSchemas}
>
  <Header slot="header" site={site} />

  <Hero
    site={site}
    primaryCta={{ label: 'Jadwalkan Test Drive', href: linkTestDrive(site, heroCar.nama), variant: 'whatsapp', iconLeft: 'whatsapp', target: '_blank' }}
    secondaryCta={{ label: 'Pelajari Teknologi SHS', href: '/teknologi', variant: 'outline' }}
  />

  <TechSection
    eyebrow="Teknologi Super Hybrid System"
    heading="Listrik untuk harian, bensin untuk jauh"
    lead="Super Hybrid System (SHS) memadukan motor listrik dan mesin bensin efisiensi tinggi. Hasilnya: kenyamanan mobil listrik untuk keseharian, dengan ketenangan jangkauan bensin saat menempuh jarak jauh."
    poin={techPoin}
    ctaHref="/teknologi"
    ctaLabel="Pelajari teknologi SHS"
  />

  <LineupSpec cars={lineup} site={site} />

  <PromoHybrid site={site} />

  <TrustHybrid site={site} />

  <DeliveryGallery site={site} />

  <!-- Area Layanan (sinyal local SEO — kalimat natural + internal link) -->
  <section class="section" id="area" aria-labelledby="area-h">
    <div class="container container--narrow">
      <div class="sec-head" data-reveal>
        <p class="eyebrow">Area Layanan</p>
        <h2 id="area-h">Melayani Semarang &amp; sekitarnya</h2>
      </div>
      <p class="area-copy" data-reveal>
        {site.dealerName} melayani pembelian dan test drive mobil hybrid &amp; listrik JAECOO untuk {kota} Kota,
        Ungaran, Salatiga, Kendal, Demak, hingga Solo (Surakarta) dan kota-kota lain di Jawa Tengah.
        Lihat <a href="/mobil/j7-shs">JAECOO J7 SHS (hybrid)</a> dan
        <a href="/mobil/j5">JAECOO J5 EV (listrik)</a>, atau pahami
        <a href="/teknologi">teknologi Super Hybrid System</a> — konsultasi &amp; test drive lintas kota
        dibantu {site.salesName} via WhatsApp.
      </p>
    </div>
  </section>

  <!-- FAQ (FAQPage JSON-LD ada di head) -->
  <section class="section section--alt" id="faq" aria-labelledby="faq-h">
    <div class="container container--narrow">
      <div class="sec-head" data-reveal>
        <p class="eyebrow">Pertanyaan Umum</p>
        <h2 id="faq-h">Seputar mobil hybrid &amp; listrik JAECOO di {kota}</h2>
      </div>
      <div class="faq" data-reveal>
        {homeFaq.map((f) => (
          <details class="faq-item">
            <summary><span>{f.q}</span><Icon name="chevron-down" size={20} class="faq-chev" /></summary>
            <div class="faq-body"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <TestDriveForm cars={lineup} site={site} preselectSlug={site.featuredSlug} />

  <StickyWhatsAppBar slot="footer" site={site} />
  <Footer slot="footer" site={site} />
</BaseLayout>

<style>
  .sec-head { display: grid; gap: var(--space-2xs); max-width: 56ch; }
  .section--alt { background: var(--color-surface-2); }
  .area-copy { margin-top: var(--space-lg); color: var(--color-text-muted); max-width: 68ch; }
  .area-copy a { color: var(--color-accent-ink); font-weight: var(--fw-semibold); text-decoration: underline; text-underline-offset: 0.18em; }
  .area-copy a:hover { color: var(--color-text); }

  .faq { display: grid; gap: var(--space-2xs); margin-top: var(--space-lg); }
  .faq-item { border-bottom: 1px solid var(--color-border); }
  .faq-item summary {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-sm);
    padding: var(--space-md) 0; cursor: pointer; list-style: none;
    font-family: var(--font-display); font-weight: var(--fw-semibold); font-size: var(--fs-h6);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-chev { color: var(--color-text-muted); transition: transform var(--dur) var(--ease); flex: none; }
  .faq-item[open] .faq-chev { transform: rotate(180deg); }
  .faq-body { padding-bottom: var(--space-md); color: var(--color-text-muted); }
</style>
