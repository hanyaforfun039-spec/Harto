---
/* Beranda Web Harto — Dealer Resmi JAECOO Semarang (umum, jual semua model
   merata). Tanpa angle hybrid/efisiensi & tanpa kalkulator. Tema terang. */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroCarousel from '../components/HeroCarousel.astro';
import LineupSpec from '../components/LineupSpec.astro';
import TrustHybrid from '../components/TrustHybrid.astro';
import DeliveryGallery from '../components/DeliveryGallery.astro';
import TestDriveForm from '../components/TestDriveForm.astro';
import StickyWhatsAppBar from '../components/StickyWhatsAppBar.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import Button from '../components/Button.astro';
import { site } from '../lib/site';
import { getLineup } from '../lib/cars';
import { organizationSchema, webSiteSchema, faqPageSchema } from '../lib/schema';

const lineup = getLineup(site);
const kota = site.address.locality;

const siteUrl = Astro.site ?? new URL('https://jaecoo-semarang.example');

/* FAQ beranda (umum, lokal) — juga FAQPage JSON-LD. */
const homeFaq = [
  {
    q: 'Model JAECOO apa saja yang tersedia di Semarang?',
    a: 'Tersedia lineup lengkap: J5, J7 SHS, J8 ARDIS, dan J8 SHS ARDIS. Lihat harga OTR dan spesifikasi tiap model di halaman ini.',
  },
  {
    q: `Apakah melayani pembelian JAECOO di luar Kota ${kota}?`,
    a: `Ya. Kami melayani ${kota}, Ungaran, Salatiga, Kendal, Demak, hingga Solo (Surakarta) dan area Jawa Tengah lainnya — termasuk test drive dan serah terima lintas kota.`,
  },
  {
    q: 'Apakah bisa dibeli secara kredit?',
    a: `Bisa. Buka halaman tiap model untuk simulasi cicilan sesuai DP dan tenor, lalu kirim hasilnya ke WhatsApp ${site.salesName} untuk diproses.`,
  },
  {
    q: 'Bagaimana cara mengatur test drive?',
    a: `Isi formulir test drive di halaman ini. Jadwal akan diatur di ${kota} dan sekitarnya sesuai waktu Anda.`,
  },
];

const homeSchemas = [
  organizationSchema(site, siteUrl.href),
  webSiteSchema(site, siteUrl.href),
  faqPageSchema(homeFaq),
];

const homeDescription =
  `Dealer resmi JAECOO Semarang: J5, J7 SHS, J8 ARDIS & J8 SHS ARDIS. ` +
  `Harga OTR terbaik, simulasi kredit & test drive. Melayani Semarang, Solo & Jawa Tengah.`;
---
<BaseLayout
  title="Beranda"
  seoTitle="Dealer Resmi JAECOO Semarang — Harga OTR, Kredit & Test Drive"
  description={homeDescription}
  jsonLd={homeSchemas}
>
  <Header slot="header" site={site} />

  <HeroCarousel site={site} />

  <LineupSpec cars={lineup} site={site} />

  <TrustHybrid site={site} />

  <DeliveryGallery site={site} />

  <!-- Area Layanan (sinyal local SEO — kalimat natural) -->
  <section class="section" id="area" aria-labelledby="area-h">
    <div class="container container--narrow">
      <div class="sec-head" data-reveal>
        <p class="eyebrow">Area Layanan</p>
        <h2 id="area-h">Melayani Semarang &amp; sekitarnya</h2>
      </div>
      <p class="area-copy" data-reveal>
        {site.dealerName} melayani pembelian dan test drive JAECOO untuk {kota} Kota,
        Ungaran, Salatiga, Kendal, Demak, hingga Solo (Surakarta) dan kota-kota lain di Jawa Tengah.
        Lihat <a href="/#lineup">lineup lengkap dan harga OTR</a> tiap model — konsultasi, kredit,
        dan test drive lintas kota dibantu {site.salesName} via WhatsApp.
      </p>
    </div>
  </section>

  <!-- Lokasi & Kontak: peta + alamat/telp/jam + tombol Maps -->
  <section class="section lokasi" id="lokasi" aria-labelledby="lokasi-h">
    <div class="container">
      <div class="sec-head" data-reveal>
        <p class="eyebrow">Kunjungi Kami</p>
        <h2 id="lokasi-h">Lokasi &amp; Kontak</h2>
      </div>
      <div class="loc-grid" data-reveal>
        <div class="loc-map">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3960.401692232946!2d110.39161139999999!3d-6.9618508!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x2e70f500523d9d1d%3A0x58749a72235a7df7!2sJAECOO%20SEMARANG!5e0!3m2!1sid!2sid!4v1782531766997!5m2!1sid!2sid"
            title="Lokasi dealer JAECOO Semarang di Google Maps"
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            allowfullscreen
          ></iframe>
        </div>

        <div class="loc-info">
          <dl class="loc-list">
            <div class="loc-item">
              <span class="loc-ico"><Icon name="map-pin" size={20} /></span>
              <div><dt>Alamat</dt><dd>{site.address.street}, {site.address.locality}, {site.address.region} {site.address.postalCode}</dd></div>
            </div>
            <div class="loc-item">
              <span class="loc-ico"><Icon name="phone" size={20} /></span>
              <div><dt>Telepon</dt><dd><a href={`tel:+${site.whatsapp}`} class="tnum">{site.phoneDisplay}</a></dd></div>
            </div>
            <div class="loc-item">
              <span class="loc-ico"><Icon name="clock" size={20} /></span>
              <div>
                <dt>Jam Operasional</dt>
                {site.openingHours.map((h) => (
                  <dd class="tnum">{h.hari}, {h.buka}–{h.tutup}</dd>
                ))}
              </div>
            </div>
          </dl>
          {site.mapUrl && (
            <Button href={site.mapUrl} variant="primary" icon="arrow-right" target="_blank">Buka di Google Maps</Button>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ (FAQPage JSON-LD ada di head) -->
  <section class="section section--alt" id="faq" aria-labelledby="faq-h">
    <div class="container container--narrow">
      <div class="sec-head" data-reveal>
        <p class="eyebrow">Pertanyaan Umum</p>
        <h2 id="faq-h">Seputar pembelian JAECOO di {kota}</h2>
      </div>
      <div class="faq" data-reveal>
        {homeFaq.map((f) => (
          <details class="faq-item">
            <summary><span>{f.q}</span><Icon name="chevron-down" size={20} class="faq-chev" /></summary>
            <div class="faq-body"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <TestDriveForm cars={lineup} site={site} preselectSlug={site.featuredSlug} />

  <StickyWhatsAppBar slot="footer" site={site} />
  <Footer slot="footer" site={site} />
</BaseLayout>

<style>
  .sec-head { display: grid; gap: var(--space-2xs); max-width: 56ch; margin-inline: auto; justify-items: center; text-align: center; }
  .section--alt { background: var(--color-surface-2); }
  .area-copy { margin-top: var(--space-lg); color: var(--color-text-muted); max-width: 68ch; }
  .area-copy a { color: var(--color-accent-ink); font-weight: var(--fw-semibold); text-decoration: underline; text-underline-offset: 0.18em; }
  .area-copy a:hover { color: var(--color-text); }

  /* Lokasi & Kontak */
  .loc-grid { margin-top: var(--space-xl); display: grid; gap: var(--space-lg); }
  @media (min-width: 56rem) { .loc-grid { grid-template-columns: 1.25fr 1fr; gap: var(--space-2xl); align-items: stretch; } }
  .loc-map {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    min-height: 18rem;
  }
  .loc-map iframe { display: block; width: 100%; height: 100%; min-height: 20rem; border: 0; }
  .loc-info {
    display: grid; align-content: start; gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }
  .loc-list { display: grid; gap: var(--space-lg); }
  .loc-item { display: flex; align-items: flex-start; gap: var(--space-md); }
  .loc-ico {
    flex: none; display: grid; place-items: center;
    width: 2.75rem; height: 2.75rem; border-radius: var(--radius-md);
    background: var(--color-accent-soft); color: var(--color-accent-ink);
    border: 1px solid var(--color-border);
  }
  .loc-item dt { font-size: var(--fs-caption); text-transform: uppercase; letter-spacing: var(--ls-wide); color: var(--color-text-subtle); }
  .loc-item dd { color: var(--color-text); font-size: var(--fs-body-sm); margin-top: 2px; }
  .loc-item dd a:hover { color: var(--color-accent-ink); }

  .faq { display: grid; gap: var(--space-2xs); margin-top: var(--space-lg); }
  .faq-item { border-bottom: 1px solid var(--color-border); }
  .faq-item summary {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-sm);
    padding: var(--space-md) 0; cursor: pointer; list-style: none;
    font-family: var(--font-display); font-weight: var(--fw-semibold); font-size: var(--fs-h6);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-chev { color: var(--color-text-muted); transition: transform var(--dur) var(--ease); flex: none; }
  .faq-item[open] .faq-chev { transform: rotate(180deg); }
  .faq-body { padding-bottom: var(--space-md); color: var(--color-text-muted); }
</style>
