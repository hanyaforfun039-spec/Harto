---
/* Halaman detail mobil — /mobil/[slug] (Tahap 4).
   Static route untuk tiap mobil di cars.json. Header detail + CarDetailSections.
   JSON-LD: Product (offers) + FAQPage + BreadcrumbList. */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Button from '../../components/Button.astro';
import StickyWhatsAppBar from '../../components/StickyWhatsAppBar.astro';
import Footer from '../../components/Footer.astro';
import CarDetailHybrid from '../../components/CarDetailHybrid.astro';
import CarImage from '../../components/CarImage.astro';
import { heroFotoOverride, heroPesan } from '../../lib/harto-detail';
import { getAllCars, hargaMulai } from '../../lib/cars';
import { site } from '../../lib/site';
import { formatRupiahShort } from '../../lib/format';
import { linkTestDrive, linkPenawaran } from '../../lib/whatsapp';
import { productSchema, faqPageSchema, breadcrumbSchema } from '../../lib/schema';
import type { Car } from '../../lib/types';

export async function getStaticPaths() {
  return getAllCars().map((car) => ({ params: { slug: car.slug }, props: { car } }));
}

interface Props { car: Car }
const { car } = Astro.props;

const powertrainLabel: Record<Car['powertrain'], string> = {
  ice: 'Bensin',
  phev: 'Hybrid Plug-in',
  ev: 'Listrik',
};
/* Kualifikasi SEO per powertrain (intent hybrid/listrik/efisiensi). */
const ptShort: Record<Car['powertrain'], string> = {
  ice: 'SUV Bensin Turbo',
  phev: 'SUV Hybrid (PHEV)',
  ev: 'SUV Listrik (EV)',
};
const ptTitle: Record<Car['powertrain'], string> = {
  ice: 'SUV Turbo Efisien',
  phev: 'SUV Hybrid PHEV',
  ev: 'SUV Listrik',
};

const harga = hargaMulai(car);
const pesan = heroPesan[car.slug] ?? car.tagline;
const waTd = linkTestDrive(site, car.nama);
const waPenawaran = linkPenawaran(site, car.nama);
const kota = site.address.locality;

/* additionalProperty Product: jenis bahan bakar (tanpa angka efisiensi). */
const fuelLabel = car.powertrain === 'ev' ? 'Listrik (EV)' : car.powertrain === 'phev' ? 'Hybrid Plug-in (PHEV)' : 'Bensin Turbo';
const additionalProperty = [{ name: 'Jenis bahan bakar', value: fuelLabel }];

const siteUrl = Astro.site ?? new URL('https://jaecoo-semarang.example');
const pageUrl = new URL(Astro.url.pathname, siteUrl).href;

const jsonLd = [
  productSchema(car, site, pageUrl, siteUrl.href, additionalProperty),
  faqPageSchema(car.faq),
  breadcrumbSchema([
    { name: 'Beranda', url: new URL('/', siteUrl).href },
    { name: 'Model', url: new URL('/#lineup', siteUrl).href },
    { name: car.namaPendek, url: pageUrl },
  ]),
];

const description =
  `JAECOO ${car.namaPendek} di ${kota} — ${ptShort[car.powertrain].toLowerCase()}. ` +
  `Harga OTR mulai ${formatRupiahShort(harga)}. Test drive & konsultasi via WhatsApp ${site.salesName}.`;

const seoTitle = `JAECOO ${car.namaPendek} ${kota} — ${ptTitle[car.powertrain]} & Harga`;
---
<BaseLayout title={car.nama} seoTitle={seoTitle} description={description} jsonLd={jsonLd}>
  <Header slot="header" site={site} />

  <!-- Hero detail: foto mobil full-bleed sebagai background -->
  <section class="hero-detail section--dark" data-surface="dark">
    <div class="hero-detail-bg" aria-hidden="true">
      <CarImage src={heroFotoOverride[car.slug] ?? car.foto.hero.src} alt={car.foto.hero.alt} label={car.namaPendek} priority ratio="16 / 9" sizes="100vw" class="hero-detail-img" />
      <span class="hero-detail-scrim"></span>
    </div>
    <div class="container hero-detail-inner">
      <nav class="crumbs" aria-label="Remah">
        <a href="/">Beranda</a>
        <span class="crumbs-sep" aria-hidden="true">/</span>
        <a href="/#lineup">Model</a>
        <span class="crumbs-sep" aria-hidden="true">/</span>
        <span aria-current="page">{car.namaPendek}</span>
      </nav>

      <div class="hd-copy" data-reveal>
        <span class="hd-rule" aria-hidden="true"></span>
        <h1>{car.nama}</h1>
        <p class="hd-lead">{pesan}</p>
        <p class="hd-price">Harga OTR mulai <span class="tnum">{formatRupiahShort(harga)}</span></p>
        <div class="hd-cta">
          <Button href={waTd} variant="whatsapp" size="lg" iconLeft="whatsapp" target="_blank">Test Drive {car.namaPendek}</Button>
          <Button href={waPenawaran} variant="outline" size="lg" iconLeft="whatsapp" target="_blank">Minta Penawaran</Button>
        </div>
      </div>
    </div>
  </section>

  <CarDetailHybrid car={car} site={site} />

  <StickyWhatsAppBar slot="footer" site={site} car={car} />
  <Footer slot="footer" site={site} />
</BaseLayout>

<style>
  /* Tinggi pas SATU LAYAR penuh DI BAWAH navbar (sticky), jadi "full gambar". */
  .hero-detail { position: relative; display: flex; overflow: hidden; min-height: calc(100svh - var(--header-h)); }
  @media (min-width: 64rem) { .hero-detail { min-height: calc(100svh - var(--header-h-lg)); } }
  .hero-detail-bg { position: absolute; inset: 0; }
  .hero-detail-bg :global(.hero-detail-img) { width: 100%; height: 100%; object-fit: cover; border-radius: 0; }
  .hero-detail-scrim {
    position: absolute; inset: 0;
    background:
      linear-gradient(180deg, rgba(6, 9, 13, 0.55) 0%, rgba(6, 9, 13, 0.28) 38%, rgba(6, 9, 13, 0.78) 100%),
      radial-gradient(120% 90% at 30% 70%, rgba(6, 9, 13, 0) 45%, rgba(6, 9, 13, 0.35) 100%);
  }

  .hero-detail-inner {
    position: relative; z-index: 1; width: 100%;
    display: flex; flex-direction: column;
    padding-block: var(--space-lg) var(--space-3xl);
  }

  .crumbs {
    display: flex; flex-wrap: wrap; gap: var(--space-2xs); align-items: center;
    font-size: var(--fs-body-sm); color: rgba(244, 246, 244, 0.78);
  }
  .crumbs a:hover { color: var(--paper); text-decoration: underline; text-underline-offset: 0.18em; }
  .crumbs span[aria-current] { color: var(--paper); font-weight: var(--fw-medium); }
  .crumbs-sep { color: rgba(244, 246, 244, 0.45); }

  .hd-copy { margin-top: auto; display: grid; gap: var(--space-sm); max-width: 42rem; }
  .hd-rule { width: 2.5rem; height: 2px; background: var(--color-accent); }
  .hd-kat { font-size: var(--fs-caption); letter-spacing: var(--ls-eyebrow); text-transform: uppercase; color: rgba(244, 246, 244, 0.8); }
  .hd-copy h1 { color: var(--paper); max-width: 18ch; font-size: clamp(2rem, 1.4rem + 3vw, 3.5rem); line-height: 1.08; }
  .hd-lead { color: rgba(244, 246, 244, 0.88); max-width: 50ch; font-size: var(--fs-lead); }
  .hd-price { color: rgba(244, 246, 244, 0.9); font-size: var(--fs-body); margin-top: var(--space-2xs); }
  .hd-price span { font-family: var(--font-display); font-size: var(--fs-h3); font-weight: var(--fw-bold); color: var(--paper); margin-left: var(--space-2xs); }
  .hd-cta { display: flex; flex-wrap: wrap; gap: var(--space-sm); margin-top: var(--space-md); }
</style>
