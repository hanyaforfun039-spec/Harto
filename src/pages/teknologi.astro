---
/* /teknologi (Web2 hybrid) — penjelasan Super Hybrid System & mobil listrik
   JAECOO + FAQ ber-schema. Bagus untuk SEO long-tail intent teknologi. */
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import TechSection from '../components/TechSection.astro';
import StickyWhatsAppBar from '../components/StickyWhatsAppBar.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import Button from '../components/Button.astro';
import { site } from '../lib/site';
import { linkPenawaran } from '../lib/whatsapp';
import { faqPageSchema, breadcrumbSchema } from '../lib/schema';

const siteUrl = Astro.site ?? new URL('https://jaecoo-semarang.example');
const pageUrl = new URL('/teknologi', siteUrl).href;

const techPoin = [
  { icon: 'battery', judul: 'Mode listrik harian', teks: 'Untuk pemakaian dalam kota, J7 SHS dapat berjalan penuh listrik — senyap, responsif, dan tanpa konsumsi bensin.' },
  { icon: 'engine', judul: 'Mesin di titik teririt', teks: 'Saat dibutuhkan, mesin bensin menyala pada putaran paling efisien sambil mengisi ulang baterai.' },
  { icon: 'power', judul: 'Tenaga instan motor listrik', teks: 'Torsi motor listrik hadir seketika — akselerasi halus dan bertenaga tanpa jeda.' },
  { icon: 'range', judul: 'Jangkauan tanpa cemas', teks: 'Gabungan bensin dan listrik memberi jarak tempuh jauh untuk perjalanan lintas kota.' },
];

const faqs = [
  {
    q: 'Apa itu SHS (Super Hybrid System) JAECOO?',
    a: 'SHS adalah sistem plug-in hybrid JAECOO yang memadukan motor listrik dan mesin bensin efisiensi tinggi. Mobil bisa berjalan penuh listrik untuk pemakaian harian, lalu memakai mesin bensin untuk jarak jauh — menggabungkan irit mobil listrik dengan ketenangan jangkauan bensin.',
  },
  {
    q: 'Berapa jarak tempuh JAECOO J7 SHS?',
    a: 'J7 SHS dapat menempuh sekitar 106 km dengan mode listrik saja (kondisi pengujian), dan jauh lebih panjang bila digabung dengan mesin bensin. Angka pasti mengikuti data resmi pabrikan dan dapat berbeda pada pemakaian nyata.',
  },
  {
    q: 'Apakah J5 EV perlu instalasi charger di rumah?',
    a: 'Tidak wajib, tetapi sangat disarankan. J5 EV bisa diisi di stasiun pengisian umum, namun home charger membuat pengisian harian lebih praktis dan murah. Kami bantu jelaskan opsi pengisian yang sesuai kebutuhan Anda.',
  },
  {
    q: 'Apakah servis mobil hybrid lebih mahal?',
    a: 'Tidak harus. Pengereman regeneratif justru memperpanjang usia kampas rem, dan interval servis mengikuti panduan pabrikan. Komponen baterai memiliki garansi resmi. Konsultasikan detail perawatan dengan kami.',
  },
];

const jsonLd = [
  faqPageSchema(faqs),
  breadcrumbSchema([
    { name: 'Beranda', url: new URL('/', siteUrl).href },
    { name: 'Teknologi', url: pageUrl },
  ]),
];

const description =
  'Penjelasan teknologi JAECOO Super Hybrid System (SHS) dan mobil listrik J5 EV: cara kerja, efisiensi, pengisian daya, dan perawatan. Konsultasi hybrid di Semarang.';
---
<BaseLayout
  title="Teknologi"
  seoTitle="Teknologi Super Hybrid System JAECOO — Cara Kerja & Manfaat"
  description={description}
  jsonLd={jsonLd}
>
  <Header slot="header" site={site} />

  <!-- Intro -->
  <section class="section tek-intro">
    <div class="container container--narrow">
      <nav class="crumbs" aria-label="Remah">
        <a href="/">Beranda</a><span aria-hidden="true">/</span><span aria-current="page">Teknologi</span>
      </nav>
      <div class="tek-head" data-reveal>
        <p class="eyebrow">Teknologi JAECOO</p>
        <h1>Super Hybrid System (SHS) &amp; Mobil Listrik JAECOO</h1>
        <p class="lead">Memahami teknologi di balik efisiensi JAECOO — bagaimana hybrid plug-in
          dan penggerak listrik bekerja, dan apa untungnya untuk pemakaian harian Anda di {site.address.locality}.</p>
      </div>
    </div>
  </section>

  <TechSection
    eyebrow="Cara Kerja"
    heading="Bagaimana Super Hybrid System bekerja"
    lead="SHS mengatur perpindahan tenaga antara motor listrik dan mesin bensin secara otomatis, selalu memilih sumber paling efisien untuk kondisi berkendara saat itu."
    poin={techPoin}
  />

  <!-- EV / pengisian daya -->
  <section class="section tek-ev">
    <div class="container container--narrow">
      <div class="tek-head" data-reveal>
        <p class="eyebrow">Mobil Listrik · J5 EV</p>
        <h2>Tenaga listrik penuh, untuk yang siap beralih</h2>
      </div>
      <div class="tek-prose" data-reveal>
        <p>JAECOO J5 EV adalah SUV listrik kompak untuk Anda yang ingin pengalaman berkendara
          paling senyap dan biaya energi paling rendah. Pengisian dapat dilakukan di stasiun
          umum maupun home charger; pengisian cepat DC mempersingkat waktu henti saat perjalanan.</p>
        <ul class="tek-list" role="list">
          <li><Icon name="battery" size={20} /> <span>Baterai LFP yang awet dengan garansi resmi pabrikan.</span></li>
          <li><Icon name="range" size={20} /> <span>Jarak tempuh harian lebih dari cukup untuk komuter kota.</span></li>
          <li><Icon name="check" size={20} /> <span>Perawatan ringkas: tanpa oli mesin, tanpa rantai distribusi.</span></li>
        </ul>
        <p class="tek-models">
          Lihat modelnya: <a href="/mobil/j5">JAECOO J5 EV</a> (listrik penuh) dan
          <a href="/mobil/j7-shs">JAECOO J7 SHS</a> (hybrid plug-in).
        </p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt" id="faq" aria-labelledby="faq-h">
    <div class="container container--narrow">
      <div class="tek-head" data-reveal>
        <p class="eyebrow">Pertanyaan Umum</p>
        <h2 id="faq-h">Seputar teknologi hybrid &amp; listrik</h2>
      </div>
      <div class="faq" data-reveal>
        {faqs.map((f) => (
          <details class="faq-item">
            <summary><span>{f.q}</span><Icon name="chevron-down" size={20} class="faq-chev" /></summary>
            <div class="faq-body"><p>{f.a}</p></div>
          </details>
        ))}
      </div>
      <div class="tek-cta" data-reveal>
        <Button href={linkPenawaran(site)} variant="accent" size="lg" iconLeft="whatsapp" target="_blank">Konsultasi hybrid gratis</Button>
      </div>
    </div>
  </section>

  <StickyWhatsAppBar slot="footer" site={site} />
  <Footer slot="footer" site={site} />
</BaseLayout>

<style>
  .crumbs {
    display: flex; flex-wrap: wrap; gap: var(--space-2xs); align-items: center;
    margin-bottom: var(--space-lg);
    font-size: var(--fs-body-sm); color: var(--color-text-muted);
  }
  .crumbs a:hover { color: var(--color-accent-ink); text-decoration: underline; }
  .crumbs span[aria-current] { color: var(--color-text); font-weight: var(--fw-medium); }
  .crumbs span[aria-hidden] { color: var(--color-text-subtle); }

  .tek-head { display: grid; gap: var(--space-sm); max-width: 60ch; }
  .tek-head h1 { max-width: 20ch; }
  .section--alt { background: var(--color-surface-2); }

  .tek-prose { margin-top: var(--space-lg); display: grid; gap: var(--space-lg); }
  .tek-prose p { color: var(--color-text-muted); }
  .tek-list { display: grid; gap: var(--space-sm); }
  .tek-list li { display: flex; align-items: flex-start; gap: var(--space-2xs); color: var(--color-text-muted); font-size: var(--fs-body-sm); }
  .tek-list :global(.icon) { color: var(--color-accent-ink); margin-top: 0.15em; flex: none; }
  .tek-models { color: var(--color-text-muted); }
  .tek-models a { color: var(--color-accent-ink); font-weight: var(--fw-semibold); text-decoration: underline; text-underline-offset: 0.18em; }

  .faq { display: grid; gap: var(--space-2xs); margin-top: var(--space-lg); }
  .faq-item { border-bottom: 1px solid var(--color-border); }
  .faq-item summary {
    display: flex; align-items: center; justify-content: space-between; gap: var(--space-sm);
    padding: var(--space-md) 0;
    cursor: pointer; list-style: none;
    font-family: var(--font-display);
    font-weight: var(--fw-semibold);
    font-size: var(--fs-h6);
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-chev { color: var(--color-text-muted); transition: transform var(--dur) var(--ease); flex: none; }
  .faq-item[open] .faq-chev { transform: rotate(180deg); }
  .faq-body { padding-bottom: var(--space-md); color: var(--color-text-muted); }

  .tek-cta { margin-top: var(--space-xl); }
</style>
